      "Nome: " + nome + "\\n" +
      "Profissão: " + profissao + "\\n\\n" +
      "Maior problema da minha marca:\\n" + problema + "\\n\\n" +
      "Por que agora:\\n" + porquenow + "\\n\\n" +
      "Investimento previsto: " + investimento
    );
    window.open("https://wa.me/5521991458033?text=" + msg, "_blank");
    this.style.display = "none";
    document.getElementById("form-sent").classList.add("active");
  });
</script>
